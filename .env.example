# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# Kafka Configuration
KAFKA_BROKER=localhost:9092
KAFKA_TOPIC=network_flows
KAFKA_CONSUMER_GROUP=ids_detector

# Model Paths
MODEL_XGB=models/xgb_model.joblib
MODEL_RF=models/rf_model.joblib
MODEL_AE=models/autoencoder.pth
MODEL_IF=models/isolation_forest.joblib
SCALER_PATH=models/scaler.joblib

# Thresholds
ANOMALY_THRESHOLD=2.5
CONFIDENCE_THRESHOLD=0.6
RISK_SCORE_THRESHOLD=0.5

# Database (optional, for alerts logging)
DB_URL=sqlite:///alerts.db

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/ids.log
